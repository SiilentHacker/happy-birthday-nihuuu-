
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Happy Birthday Nihuu</title>
    <style>
        :root {
            --purple-bg: #2d1b4e;
            --romantic-pink: #ff4d6d;
            --soft-purple: #7b2cbf;
        }

        body {
            margin: 0;
            padding: 0;
            background-color: var(--purple-bg);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: white;
            overflow-x: hidden;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        /* Flying Hearts Animation */
        .heart-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: -1;
        }

        .heart {
            position: absolute;
            color: var(--romantic-pink);
            animation: fly 10s linear infinite;
            opacity: 0.6;
        }

        @keyframes fly {
            0% { transform: translateY(100vh) rotate(0deg); opacity: 1; }
            100% { transform: translateY(-10vh) rotate(360deg); opacity: 0; }
        }

        .container {
            width: 90%;
            max-width: 600px;
            text-align: center;
            padding: 40px 20px;
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            margin: 20px 0;
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

        h1 { font-size: 2.5rem; color: var(--romantic-pink); }
        
        .speech-box {
            text-align: left;
            line-height: 1.6;
            background: rgba(0, 0, 0, 0.2);
            padding: 20px;
            border-radius: 15px;
            margin-bottom: 30px;
            white-space: pre-line;
            font-size: 1.1rem;
        }

        .proposal-section {
            margin-top: 50px;
            padding: 20px;
            border-top: 2px dashed var(--soft-purple);
        }

        .btn-container {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 20px;
            height: 100px;
            align-items: center;
            position: relative;
        }

        button {
            padding: 15px 30px;
            font-size: 1.2rem;
            border: none;
            border-radius: 50px;
            cursor: pointer;
            transition: 0.3s;
        }

        #yesBtn { background-color: var(--romantic-pink); color: white; }
        #noBtn { 
            background-color: #555; 
            color: white; 
            position: absolute;
            transition: all 0.2s ease;
        }

        #message {
            margin-top: 20px;
            font-weight: bold;
            color: #ffb3c1;
            min-height: 24px;
        }

        .success-screen {
            display: none;
            text-align: center;
            animation: fadeIn 2s forwards;
        }

        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        .footer {
            margin-top: 40px;
            padding: 20px;
            font-style: italic;
            color: var(--romantic-pink);
        }

        .bouquet { font-size: 3rem; margin-top: 10px; }

        @media (max-width: 480px) {
            h1 { font-size: 1.8rem; }
            .speech-box { font-size: 0.95rem; }
        }
    </style>
</head>
<body>

<div class="heart-bg" id="heartBg"></div>

<div class="container" id="mainContent">
    <h1>Happy Birthday Nihuu! 🎂</h1>
    
    <div class="speech-box">
        Happy birthday nihuu 🎂🥺

        dear love 
        May mash er ei misty rod er moto apner jibon ta jeno sob smy ujjol takhe 🤲🏻...amdr ek shate katano protita moment amr kache sriti hoiye takhbe 😊....ebabhei sharajibon pashe chai apnk priotoma....🫂 dua kori sob smy kushi takho amr shate 😊...amdr karor nojor na laguk🥹 ...agiye jw kw takuk na takuk , ami sob smy tmr pashe dal hoiye darabo🤗

        Kkno Jodi bhul kori maaf kore diyen ....Ami apnk haraite chai na prio 😭.....Dua Kori sob smy kushi takhen ...Allah amdr 2jon k 2jon er jno kobul koruk (Ameen) 🤲🏻

        Sorry beshi romantic hower jno ...ki korbo Ami apner kache ashlei erkm hoi Jai 🥲🥲....plz amk eghular jno Mon teke utai diyen na ...Ami parbo na nije k shamlaite ....😭

        Apner babu Apnk ja promise korse sob korbe inshaallah shudu ektu pashe takhiyen amr ....Ami kibabe bolle apni bishash korben Jani na ...amr pgl apner jno .....🤲🏻

        Ei bishaal Akash poriman valobashi apnk 💗...Jani na apner jno ki korte parbo life a kintu eituk e bolte parbo apner ei pgl ta apnr shate kkno cheat korbe ...jkn teke apni amk shujug diyechen nijek apner jno toiri korchi 🤗

        Ami Jani na Ami apner mone kotuk jaiga niye achi kintu bishash koren amr Pura Mon jure shudu apni ...💖....thank you amr life a ashar jno ...Ami nijek onk lucky mne korbo apnk amr soulmate hishebe nijer kore nite parle 😌☺️

        Happy birthday nihuuuu 😘
        I love you baby 💖
    </div>

    <div class="proposal-section">
        <h2>Will you marry me, Nihla?</h2>
        <div class="btn-container">
            <button id="yesBtn" onclick="celebrate()">Yes</button>
            <button id="noBtn" onmouseover="moveNo()" onclick="moveNo()">No</button>
        </div>
        <p id="message"></p>
    </div>
</div>

<div class="success-screen" id="successScreen">
    <h1 style="font-size: 3rem;">I love you baby Afra 💖</h1>
    <p style="font-size: 1.5rem;">Inshaallah we will get married soon..<br>Allah grant us as a soulmate... 💖</p>
    <div style="font-size: 100px;">💍👩‍❤️‍👨</div>
</div>

<div class="footer">
    <p>Imran 💖 Afra</p>
    <div class="bouquet">💐🌷🌹</div>
</div>

<script>
    // Create flying hearts
    function createHearts() {
        const bg = document.getElementById('heartBg');
        for (let i = 0; i < 20; i++) {
            const heart = document.createElement('div');
            heart.className = 'heart';
            heart.innerHTML = '❤';
            heart.style.left = Math.random() * 100 + 'vw';
            heart.style.animationDuration = (Math.random() * 5 + 5) + 's';
            heart.style.fontSize = (Math.random() * 20 + 10) + 'px';
            bg.appendChild(heart);
        }
    }
    createHearts();

    const messages = [
        "Plz na boilo na 😭",
        "Ami kosto pabo 😭",
        "Ice cream dibo onk gula 🍦😔",
        "Don't do this to me 😭",
        "Pura Mon jure shudu apni 😭"
    ];
    let msgIndex = 0;

    function moveNo() {
        const btn = document.getElementById('noBtn');
        const msg = document.getElementById('message');
        
        // Move button
        const x = Math.random() * (window.innerWidth - 100);
        const y = Math.random() * (window.innerHeight - 50);
        
        btn.style.position = 'fixed';
        btn.style.left = x + 'px';
        btn.style.top = y + 'px';

        // Update emotional message
        msg.innerText = messages[msgIndex];
        msgIndex = (msgIndex + 1) % messages.length;
    }

    function celebrate() {
        document.getElementById('mainContent').style.display = 'none';
        document.getElementById('successScreen').style.display = 'block';
        window.scrollTo(0,0);
        
        // Add more hearts for celebration
        setInterval(() => {
            const heart = document.createElement('div');
            heart.className = 'heart';
            heart.innerHTML = '💖';
            heart.style.left = Math.random() * 100 + 'vw';
            heart.style.animationDuration = '3s';
            document.body.appendChild(heart);
        }, 300);
    }
</script>

</body>
</html>
